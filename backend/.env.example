# Copy to .env and fill in real values. Never commit .env.

# ---- Application ----
NODE_ENV=development
APP_NAME=grievance-platform-backend
PORT=3000
API_PREFIX=/api/v1
TRUST_PROXY=false

# ---- CORS ----
# Comma-separated list of allowed origins, e.g. https://portal.tambaram.gov.in,https://admin.tambaram.gov.in
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ---- Logging ----
LOG_LEVEL=debug
LOG_DIR=logs

# ---- MySQL / Sequelize ----
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=grievance_platform
DB_USER=grievance_app
DB_PASSWORD=change-me
DB_DIALECT=mysql
DB_POOL_MAX=10
DB_POOL_MIN=0
DB_POOL_ACQUIRE_MS=30000
DB_POOL_IDLE_MS=10000
DB_LOGGING=false

# ---- Redis (cache + BullMQ) ----
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false

# ---- JWT (RS256, bearerAuth per docs/components/securitySchemes.yaml) ----
# PEM file paths, relative to backend/. Generate a dev keypair with:
#   openssl genrsa -out src/config/keys/jwt-private.pem 2048
#   openssl rsa -in src/config/keys/jwt-private.pem -pubout -out src/config/keys/jwt-public.pem
JWT_PRIVATE_KEY_PATH=src/config/keys/jwt-private.pem
JWT_PUBLIC_KEY_PATH=src/config/keys/jwt-public.pem
JWT_ISSUER=grievance-platform
JWT_AUDIENCE=grievance-platform-clients
JWT_ACCESS_TOKEN_TTL_SECONDS=900
JWT_REFRESH_TOKEN_TTL_SECONDS=604800

# ---- OTP (docs/authentication.yaml, docs/14-API-Security.md §14.4) ----
OTP_TTL_SECONDS=300
OTP_RESEND_COOLDOWN_SECONDS=30
OTP_REQUEST_MAX_PER_WINDOW=3
OTP_REQUEST_WINDOW_SECONDS=600
OTP_MAX_VERIFY_ATTEMPTS=5

# ---- MFA (TOTP, Corporation Admin / Super Admin only) ----
MFA_CHALLENGE_TTL_SECONDS=300

# ---- Account security (SRS §8.1) ----
LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_LOCKOUT_SECONDS=900
PASSWORD_RESET_TTL_SECONDS=1800
PASSWORD_HISTORY_LIMIT=5

# ---- Seed-only: bootstrap Super Admin credentials (see src/seeders) ----
SEED_ADMIN_EMAIL=admin@tambaram.gov.in
SEED_ADMIN_PASSWORD=ChangeMe!123

# ---- File uploads (Multer) ----
UPLOAD_TMP_DIR=uploads/tmp
UPLOAD_MAX_FILE_SIZE_BYTES=10485760

# ---- Swagger UI ----
SWAGGER_ENABLED=true
SWAGGER_ROUTE=/api-docs
